# Copy to .env for local development. NEVER commit .env (it's in .gitignore).

# --- Auth mode: "bearer" (simple, default) or "oauth" (for Claude.ai Custom Connectors) ---
AUTH_MODE=bearer

# --- Bearer-token auth ---
# Required when AUTH_MODE=bearer. Generate with: openssl rand -hex 32
# Any string works; use something long and random in production.
MCP_API_KEY=replace-me-with-a-long-random-string

# --- OAuth auth (only used when AUTH_MODE=oauth) ---
# Issuer URL — must be a stable HTTPS URL your AI clients can reach.
# In production, this is your Railway domain (e.g., https://your-gateway.up.railway.app).
OAUTH_ISSUER_URL=

# A 32-byte secret for signing JWTs. Generate with: openssl rand -hex 32
OAUTH_JWT_SECRET=

# --- Vault location ---
# Path to the markdown notes the gateway exposes. Default: ./notes in the repo.
# In production you might mount a volume here.
NOTES_DIR=./notes

# --- Server ---
# Railway sets PORT automatically; only override for local dev.
PORT=8000
